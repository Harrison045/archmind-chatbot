# ArchMind — Python backend / terminal chatbot config
# Copy this file to `.env` and fill in your values. `.env` is git-ignored.

# Your OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Any model available on OpenRouter (e.g. anthropic/claude-sonnet-4-5, openai/gpt-4o)
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
