# ArchMind — Python backend / terminal chatbot config
# Copy this file to `.env` and fill in your values. `.env` is git-ignored.
#
# Provider selection: if ANTHROPIC_API_KEY is set, ArchMind talks to Anthropic
# directly. Otherwise it falls back to OpenRouter. You only need ONE of them.

# --- Anthropic (preferred when set) -----------------------------------------
# Direct Anthropic key (starts with sk-ant-…). Get one at https://console.anthropic.com
# Requires credits on your Anthropic account (Plans & Billing).
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- OpenRouter (fallback) ---------------------------------------------------
# Your OpenRouter API key (starts with sk-or-…) — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Shared model settings ---------------------------------------------------
# Model id. Use a vision-capable model for image analysis (Claude, GPT-4o, …).
# Anthropic provider strips the "anthropic/" prefix automatically.
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Max output tokens per reply. Providers reserve credits for the full amount up
# front, so a low cap keeps requests affordable on a small balance. Raise it once
# your account is funded for longer answers.
OPENROUTER_MAX_TOKENS=2048
